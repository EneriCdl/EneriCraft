{
  "$schema": "https://raw.githubusercontent.com/nicepkg/vscode-tauri/main/tauri.conf.schema.json",
  "productName": "MC 联机器",
  "version": "0.1.0",
  "identifier": "com.mcconnector.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "title": "MC 联机器",
    "windows": [
      {
        "label": "main",
        "title": "MC 联机器",
        "width": 960,
        "height": 680,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "MC Connector Community",
    "copyright": "GPL-3.0 © MC Connector Community"
  }
}
